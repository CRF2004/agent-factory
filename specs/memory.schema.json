{
  "$defs": {
    "MemoryStatus": {
      "enum": [
        "candidate",
        "approved",
        "active",
        "deprecated",
        "rejected",
        "conflict"
      ],
      "title": "MemoryStatus",
      "type": "string"
    },
    "MemoryType": {
      "enum": [
        "knowledge",
        "experience",
        "skill"
      ],
      "title": "MemoryType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "created_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Created At"
    },
    "updated_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Updated At"
    },
    "id": {
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "type": {
      "$ref": "#/$defs/MemoryType"
    },
    "title": {
      "minLength": 1,
      "title": "Title",
      "type": "string"
    },
    "content": {
      "minLength": 1,
      "title": "Content",
      "type": "string"
    },
    "summary": {
      "default": "",
      "title": "Summary",
      "type": "string"
    },
    "source": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source"
    },
    "source_task_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Task Id"
    },
    "source_run_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Run Id"
    },
    "status": {
      "$ref": "#/$defs/MemoryStatus",
      "default": "candidate"
    },
    "confidence": {
      "default": 0.5,
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "reliability_score": {
      "anyOf": [
        {
          "maximum": 1.0,
          "minimum": 0.0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Reliability Score"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "title": "Tags",
      "type": "array"
    },
    "related_projects": {
      "items": {
        "type": "string"
      },
      "title": "Related Projects",
      "type": "array"
    },
    "created_by_agent_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Created By Agent Id"
    }
  },
  "required": [
    "id",
    "type",
    "title",
    "content"
  ],
  "title": "MemoryItem",
  "type": "object"
}
